----------------------------------------------------------------
-- ANTI-CHEAT ENGINE  (client-side monitoring of other players)
-- Since this runs on the client we monitor visible player data
-- position, speed, and proximity to known farm coordinates
----------------------------------------------------------------
local acLastPos = {}
local acTimer   = 0
local acFlagged = {}

RunService.Heartbeat:Connect(function(dt)
    if not ACState.Enabled then return end
    acTimer = acTimer + dt
    if acTimer < 0.5 then return end
    acTimer = 0

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not root or not hum then continue end

        local pos = root.Position
        local flagged = false
        local reason  = ""

        -- SPEED CHECK
        if ACState.SpeedCheck and acLastPos[player] then
            local dist  = (pos - acLastPos[player]).Magnitude
            local speed = dist / 0.5 -- per 0.5s tick
            if speed > ACState.MaxSpeed * 2 then
                flagged = true
                reason  = string.format("Speed hack (%.0f studs/s)", speed)
            end
        end

        -- FARM COORD CHECK
        if ACState.FarmCheck and not flagged then
            for _, coord in ipairs(ACState.FarmCoords) do
                local dist = (pos - coord).Magnitude
                if dist < ACState.FarmRadius then
                    flagged = true
                    reason  = string.format("Near farm coord (%.0f, %.0f, %.0f) dist=%.1f",
                        coord.X, coord.Y, coord.Z, dist)
                    break
                end
            end
        end

        -- FLY CHECK (off ground by more than 10 studs, not jumping)
        if ACState.FlyCheck and not flagged then
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {char}
            rayParams.FilterType = Enum.RaycastFilterType.Exclude
            local result = workspace:Raycast(pos, Vector3.new(0,-10,0), rayParams)
            if not result and hum.FloorMaterial == Enum.Material.Air then
                -- Check they've been in air for a while
                if not acFlagged[player.."_airTime"] then
                    acFlagged[player.."_airTime"] = tick()
                elseif tick() - acFlagged[player.."_airTime"] > 3 then
                    flagged = true
                    reason  = "Possible fly hack (airborne >3s)"
                end
            else
                acFlagged[player.."_airTime"] = nil
            end
        end

        -- LOG if flagged and not already logged recently
        if flagged then
            local key = player.Name.."_"..reason
            if not acFlagged[key] or tick() - acFlagged[key] > 10 then
                acFlagged[key] = tick()
                local msg = "⚠ "..player.Name.." — "..reason
                addLog(msg, T.accent)
                notify("⚠ Exploit Detected", player.Name..": "..reason, nil)
                print("[C3 Anti-Cheat] "..msg)
            end
        end

        acLastPos[player] = pos
    end
end)

-- Clean up when player leaves
Players.PlayerRemoving:Connect(function(player)
    acLastPos[player] = nil
end)

