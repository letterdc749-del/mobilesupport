-- Slow Travel state
local SlowTravel = {
    Active   = false,
    Target   = nil,
    Name     = "",
    Speed    = 20, -- studs per second — just under max AC speed
    Conn     = nil,
}

local function stopSlowTravel()
    if SlowTravel.Conn then
        SlowTravel.Conn:Disconnect()
        SlowTravel.Conn = nil
    end
    SlowTravel.Active = false
    SlowTravel.Target = nil
    SlowTravel.Name   = ""
end

local function startSlowTravel(targetPos, locName)
    stopSlowTravel()
    SlowTravel.Active = true
    SlowTravel.Target = targetPos
    SlowTravel.Name   = locName
    notify("Travelling", "→ " .. locName, nil)

    local UNDERGROUND_Y = 500  -- travel high above the map

    local function disableCollisions()
        local c = LP.Character
        if not c then return end
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end

    local function zeroVelocity(root)
        root.AssemblyLinearVelocity  = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end

    -- Phase tracker: 1=sink, 2=travel underground, 3=rise
    local phase = 1

    SlowTravel.Conn = RunService.Heartbeat:Connect(function(dt)
        if not SlowTravel.Active then return end
        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then stopSlowTravel(); return end

        disableCollisions()
        zeroVelocity(root)

        local pos = root.Position

        if phase == 1 then
            -- Sink straight down to underground Y at current X,Z
            local sinkTarget = Vector3.new(pos.X, UNDERGROUND_Y, pos.Z)
            local diff = sinkTarget - pos
            if math.abs(diff.Y) < 5 then
                root.CFrame = CFrame.new(sinkTarget)
                phase = 2
                return
            end
            local step = math.min(120 * dt, math.abs(diff.Y))
            root.CFrame = CFrame.new(pos + Vector3.new(0, -step, 0))

        elseif phase == 2 then
            -- Travel underground horizontally to destination X,Z
            local underTarget = Vector3.new(targetPos.X, UNDERGROUND_Y, targetPos.Z)
            local diff = underTarget - pos
            local horizDist = Vector3.new(diff.X, 0, diff.Z).Magnitude
            if horizDist < 5 then
                root.CFrame = CFrame.new(underTarget)
                phase = 3
                return
            end
            local step = math.min(SlowTravel.Speed * dt, horizDist)
            local dir = Vector3.new(diff.X, 0, diff.Z).Unit
            root.CFrame = CFrame.new(pos + dir * step)

        elseif phase == 3 then
            -- Rise up to target Y
            local diff = targetPos - pos
            if diff.Magnitude < 4 then
                root.CFrame = CFrame.new(targetPos)
                local name = SlowTravel.Name
                stopSlowTravel()
                notify("Arrived", "✓  " .. name, "success")
                return
            end
            local step = math.min(80 * dt, math.abs(diff.Y))
            root.CFrame = CFrame.new(pos + Vector3.new(0, step, 0))
        end
    end)
end

