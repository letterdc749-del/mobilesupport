-- USERNAME CHANGER LOGIC
-- Targets RankTagClone > MainFrame > NameLabel (the top @username label)
local function getUsernameLabel(char)
    if not char then return nil end
    local head = char:FindFirstChild("Head")
    if not head then return nil end
    -- Server creates BillboardGui named "RankTag" for the username row
    local rankTag = head:FindFirstChild("RankTag")
        or head:FindFirstChild("RankTagClone")
    if rankTag then
        local mf = rankTag:FindFirstChild("MainFrame", true)
        if mf then
            return mf:FindFirstChild("NameLabel", true)
        end
    end
    -- Fallback: label whose text matches LP.Name
    for _, obj in ipairs(head:GetDescendants()) do
        if obj:IsA("TextLabel") then
            local t = obj.Text
            if t and (t == LP.Name or t:match("^@")) then
                return obj
            end
        end
    end
    return nil
end

local function patchUsername(char, newName)
    -- If custom tag is active, update the full tag format
    -- so the two features don't fight over the same label
    if tagEnabled then
        local lbl = getRankLabel(char)
        if lbl then
            pcall(function()
                lbl.Text       = tagCustom .. "  |  " .. newName
                lbl.TextColor3 = Color3.fromRGB(0, 0, 0)
            end)
        end
    else
        local lbl = getUsernameLabel(char)
        if lbl then pcall(function() lbl.Text = newName end) end
    end
end

local function restoreUsername(char)
    local lbl = getUsernameLabel(char)
    if lbl and ucOrigName then
        pcall(function() lbl.Text = ucOrigName end)
    end
end

