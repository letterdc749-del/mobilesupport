-------------------------------------------------
-- AIMLOCK TARGET FINDER (shared by aimlock + silent aim)
-------------------------------------------------
local function getAimTarget()
    local center   = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y/2)
    local best, bestVal = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        local char = p.Character
        if not char then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then continue end
        local sp, vis = Cam:WorldToScreenPoint(root.Position)
        if not vis then continue end
        local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if screenDist > S.Aimlock.FOV then continue end
        local val = S.Aimlock.Priority == "Closest" and screenDist or hum.Health
        if val < bestVal then
            best, bestVal = p, val
        end
    end
    return best
end

-------------------------------------------------
-- SILENT AIM
-- Safe approach: uses a MouseMoveFilter to
-- intercept mouse delta and apply a corrective
-- offset toward the target. No metatable hooks.
-- Works by computing the screen-space delta
-- between cursor and target each frame, then
-- lerping the camera's ViewModel aim direction.
-------------------------------------------------
local saOldCF = nil

-------------------------------------------------
-- WALLBANG (safe iteration — collect then destroy)
-------------------------------------------------
local wbTimer  = 0
local wbActive = {}  -- array of active highlights (separate from hash)

local function clearWallbangSafe()
    -- FIX: collect keys first, then destroy — never mutate during pairs()
    local toRemove = {}
    for part, hl in pairs(S.Wallbang.Highlights) do
        table.insert(toRemove, {part=part, hl=hl})
    end
    for _, entry in ipairs(toRemove) do
        pcall(function() entry.hl:Destroy() end)
        S.Wallbang.Highlights[entry.part] = nil
    end
end

local function isPenetrable(part)
    if part.Transparency >= 0.5 then return true end
    if not part.CanCollide then return true end
    local ok, density = pcall(function()
        return part.CurrentPhysicalProperties.Density
    end)
    if ok and density < 0.5 then return true end
    local size = part.Size
    if size.X < 0.5 or size.Y < 0.5 or size.Z < 0.5 then return true end
    return false
end

-------------------------------------------------
-- MASTER RENDER LOOP
-- Single RenderStepped handles:
-- drag, crosshair, aimlock, tracers,
-- esp enable/disable, silent aim, slider
-------------------------------------------------
local fpsCount, fpsTimer = 0, 0
local pingTimer = 0

RunService.RenderStepped:Connect(function(dt)

    -- DRAG (mouse + touch)
    if S.GUI.Dragging then
        local mp
        if IS_MOBILE then
            local touches = UserInputService:GetTouchPositions()
            mp = #touches > 0 and touches[1] or UserInputService:GetMouseLocation()
        else
            mp = UserInputService:GetMouseLocation()
        end
        Main.Position = UDim2.new(0, mp.X - S.GUI.DragOff.X, 0, mp.Y - S.GUI.DragOff.Y)
    end

    -- SLIDER (single shared handler — works for mouse and touch)
    if S.ActiveSlider then
        local sl = S.ActiveSlider
        local inputX
        if IS_MOBILE then
            local touches = UserInputService:GetTouchPositions()
            inputX = #touches > 0 and touches[1].X or UserInputService:GetMouseLocation().X
        else
            inputX = UserInputService:GetMouseLocation().X
        end
        local rel = math.clamp(
            (inputX - sl.track.AbsolutePosition.X) / sl.track.AbsoluteSize.X, 0, 1
        )
        local v = sl.minV + rel * (sl.maxV - sl.minV)
        sl.fill.Size    = UDim2.new(rel, 0, 1, 0)
        sl.dot.Position = UDim2.new(rel, 0, 0.5, 0)
        sl.setVal(v)
        if sl.cb then sl.cb(v) end
    end

    -- CROSSHAIR
    if S.Crosshair.Enabled then
        local vp     = Cam.ViewportSize
        local cx, cy = vp.X/2, vp.Y/2
        local style  = S.Crosshair.Style
        CH.dot.Visible  = style == "Dot"
        CH.h.Visible    = style == "Cross"
        CH.v.Visible    = style == "Cross"
        CH.circ.Visible = style == "Circle"
        if style == "Dot" then
            CH.dot.Position = Vector2.new(cx, cy)
        elseif style == "Cross" then
            CH.h.From = Vector2.new(cx-9, cy); CH.h.To = Vector2.new(cx+9, cy)
            CH.v.From = Vector2.new(cx, cy-9); CH.v.To = Vector2.new(cx, cy+9)
        elseif style == "Circle" then
            CH.circ.Position = Vector2.new(cx, cy)
        end
    else
        CH.dot.Visible  = false
        CH.h.Visible    = false
        CH.v.Visible    = false
        CH.circ.Visible = false
    end

    -- AIMLOCK
    AimCircle.Visible  = S.Aimlock.Enabled
    AimCircle.Radius   = S.Aimlock.FOV
    AimCircle.Position = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y/2)

    if S.Aimlock.Enabled and (UserInputService:IsKeyDown(S.Aimlock.Key) or (IS_MOBILE and mobileAimHeld)) then
        local target = getAimTarget()
        if target then
            local char = target.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                Cam.CFrame = Cam.CFrame:Lerp(
                    CFrame.new(Cam.CFrame.Position, root.Position + Vector3.new(0,1.5,0)),
                    S.Aimlock.Smooth
                )
            end
        end
    end

    -- SILENT AIM
    -- Approach: offset the camera's CFrame subtly toward the target
    -- so the bullet origin aligns, then restore next frame.
    -- This avoids any metatable hooks entirely.
    if S.SilentAim.Enabled then
        local target = getAimTarget()
        if target then
            local char = target.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                local aimPos = root.Position + Vector3.new(0, 1.5, 0)
                saOldCF = Cam.CFrame
                -- Gently blend look direction without moving position
                Cam.CFrame = CFrame.new(Cam.CFrame.Position, aimPos)
            end
        end
    end

    -- TRACERS
    if S.Tracers.Enabled then
        local origin = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y)
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LP then continue end
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                local sp, onScreen = Cam:WorldToScreenPoint(root.Position)
                if onScreen then
                    if not S.Tracers.Lines[player] then
                        local line = newDrawing("Line")
                        line.Thickness    = 1
                        line.Color        = C.red
                        line.Transparency = 0.2
                        S.Tracers.Lines[player] = line
                    end
                    S.Tracers.Lines[player].From    = origin
                    S.Tracers.Lines[player].To      = Vector2.new(sp.X, sp.Y)
                    S.Tracers.Lines[player].Visible = true
                else
                    if S.Tracers.Lines[player] then
                        S.Tracers.Lines[player].Visible = false
                    end
                end
            else
                if S.Tracers.Lines[player] then
                    S.Tracers.Lines[player].Visible = false
                end
            end
        end
    else
        for _, line in pairs(S.Tracers.Lines) do
            if line then line.Visible = false end
        end
    end

    -- ESP enable/disable check
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        if S.ESP.Enabled then
            if not S.ESP.Tags[player] and player.Character then
                buildESP(player)
            end
        else
            if S.ESP.Tags[player] or S.ESP.Highlights[player] then
                removeESP(player)
            end
        end
    end

    -- NOCLIP
    if S.Noclip.Enabled then
        local char = LP.Character
        if char then
            for _, p in ipairs(char:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end
    end

    -- HUD OVERLAY
    local anyHUD = S.Overlay.FPS or S.Overlay.Ping or S.Overlay.Coords or S.Overlay.Clock
    HUD.Visible = anyHUD

    if S.Overlay.FPS then
        fpsCount = fpsCount + 1
        fpsTimer = fpsTimer + dt
        if fpsTimer >= 0.5 then
            local fps = math.floor(fpsCount / fpsTimer)
            FPSLabel.Text       = "FPS  " .. fps
            FPSLabel.TextColor3 = fps >= 55 and C.green or fps >= 30 and C.yellow or C.red
            fpsCount, fpsTimer  = 0, 0
        end
    end
    FPSLabel.Visible = S.Overlay.FPS

    pingTimer = pingTimer + dt
    if S.Overlay.Ping and pingTimer >= 1 then
        pingTimer = 0
        local ok, p = pcall(function() return LP:GetNetworkPing() end)
        if ok then
            local ms = math.floor(p * 1000)
            PingLabel.Text       = "PING  " .. ms .. "ms"
            PingLabel.TextColor3 = ms < 80 and C.green or ms < 150 and C.yellow or C.red
        end
    end
    PingLabel.Visible = S.Overlay.Ping

    -- COORDINATES
    if S.Overlay.Coords then
        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            local p = root.Position
            CoordsLabel.Text = string.format("XYZ  %d, %d, %d", math.floor(p.X), math.floor(p.Y), math.floor(p.Z))
        end
    end
    CoordsLabel.Visible = S.Overlay.Coords

    -- CLOCK
    if S.Overlay.Clock then
        local t = os.date("*t")
        ClockLabel.Text = string.format("TIME  %02d:%02d:%02d", t.hour, t.min, t.sec)
    end
    ClockLabel.Visible = S.Overlay.Clock

    -- HP BAR
    HPBarBG.Visible = S.Overlay.HPBar
    if S.Overlay.HPBar then
        local char = LP.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            local pct = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
            HPBarFill.Size             = UDim2.new(pct, 0, 1, 0)
            HPBarFill.BackgroundColor3 = pct > 0.5 and C.green or pct > 0.25 and C.yellow or C.red
            HPBarText.Text             = math.floor(hum.Health) .. " / " .. math.floor(hum.MaxHealth)
        end
    end

    -- FLY
    if S.Fly.Enabled and S.Fly.Body and S.Fly.Gyro then
        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root and S.Fly.Body.Parent then
            local vel = Vector3.zero
            local cf  = Cam.CFrame
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - cf.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + cf.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + Vector3.yAxis end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel = vel - Vector3.yAxis end
            S.Fly.Body.Velocity = vel * S.Fly.Speed
            S.Fly.Gyro.CFrame   = cf
        end
    end
end)

-------------------------------------------------
-- WALLBANG  (Heartbeat, throttled, safe iter)
-------------------------------------------------
RunService.Heartbeat:Connect(function(dt)
    if not S.Wallbang.Enabled then
        if next(S.Wallbang.Highlights) then clearWallbangSafe() end
        return
    end

    wbTimer = wbTimer + dt
    if wbTimer < 0.15 then return end
    wbTimer = 0

    clearWallbangSafe()

    local char = LP.Character
    if not char then return end
    S.Wallbang.rayParams.FilterDescendantsInstances = {char}

    local castOrigin = Cam.CFrame.Position
    local lookVec    = Cam.CFrame.LookVector
    local direction  = lookVec * 300

    for _ = 1, 5 do
        local result = workspace:Raycast(castOrigin, direction, S.Wallbang.rayParams)
        if not result then break end
        local part = result.Instance
        if part and part:IsA("BasePart") and isPenetrable(part) then
            if not S.Wallbang.Highlights[part] then
                local hl = Instance.new("Highlight")
                hl.FillColor           = C.orange
                hl.OutlineColor        = C.orange
                hl.FillTransparency    = 0.5
                hl.OutlineTransparency = 0.1
                hl.Adornee             = part
                hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
                hl.Parent              = part
                S.Wallbang.Highlights[part] = hl
            end
        end
        castOrigin = result.Position + lookVec * 0.05
    end
end)

