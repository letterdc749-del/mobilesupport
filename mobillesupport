-- FREECAM SYSTEM
----------------------------------------------------------------
local fcCF   = CFrame.new(0,10,0)  -- current camera CFrame
local fcYaw  = 0
local fcPitch = 0
local fcMouseLast = nil

RunService.RenderStepped:Connect(function(dt)
    if not S.FreeCam.Enabled then return end

    local spd = S.FreeCam.Speed * dt
    local vel = Vector3.zero
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + fcCF.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - fcCF.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - fcCF.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + fcCF.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.E) then vel = vel + Vector3.yAxis end
    if UserInputService:IsKeyDown(Enum.KeyCode.Q) then vel = vel - Vector3.yAxis end

    -- Mouse look
    local mouseDelta = UserInputService:GetMouseDelta()
    fcYaw   = fcYaw   - mouseDelta.X * 0.3
    fcPitch = math.clamp(fcPitch - mouseDelta.Y * 0.3, -89, 89)

    local rot = CFrame.Angles(0, math.rad(fcYaw), 0)
        * CFrame.Angles(math.rad(fcPitch), 0, 0)

    if vel.Magnitude > 0 then
        fcCF = CFrame.new(fcCF.Position + vel.Unit * spd) * rot
    else
        fcCF = CFrame.new(fcCF.Position) * rot
    end

    Cam.CFrame = fcCF
end)

-- Toggle freecam with C key, lock mouse during freecam
connect(UserInputService.InputBegan, function(inp, gpe)
    if gpe or S.Listening then return end
    if inp.KeyCode == Enum.KeyCode.C then
        S.FreeCam.Enabled = not S.FreeCam.Enabled
        if S.FreeCam.Enabled then
            -- Snapshot current cam position so freecam starts there
            fcCF = Cam.CFrame
            local _, yaw, _ = Cam.CFrame:ToEulerAnglesYXZ()
            fcYaw = math.deg(yaw)
            fcPitch = 0
            Cam.CameraType = Enum.CameraType.Scriptable
            UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
            notify("Freecam", "ON — WASD + QE + mouse look", "success")
        else
            Cam.CameraType = Enum.CameraType.Custom
            Cam.CameraSubject = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid") or nil
            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
            notify("Freecam", "OFF", nil)
        end
    end
end)

