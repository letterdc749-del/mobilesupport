-- Two-button option selector
local function OptionPair(parent, optA, optB, current, cb)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1,0,0,36); row.BackgroundTransparency = 1

    local function makeOpt(label, x, isActive)
        local b = Instance.new("TextButton", row)
        b.Text = label; b.Font = Enum.Font.Gotham; b.TextSize = 12
        b.Size = UDim2.new(0.5,-4,1,0); b.Position = UDim2.new(x,x==0 and 0 or 8,0,0)
        b.BorderSizePixel = 0; b.AutoButtonColor = false
        b.BackgroundColor3 = isActive and T.accent or T.card
        b.TextColor3 = isActive and T.white or T.mute
        Instance.new("UICorner", b).CornerRadius = UDim.new(0,6)
        return b
    end

    local bA = makeOpt(optA, 0,   current == optA)
    local bB = makeOpt(optB, 0.5, current == optB)

    local function pick(v)
        TweenService:Create(bA,TweenInfo.new(0.1),{BackgroundColor3=v==optA and T.accent or T.card, TextColor3=v==optA and T.white or T.mute}):Play()
        TweenService:Create(bB,TweenInfo.new(0.1),{BackgroundColor3=v==optB and T.accent or T.card, TextColor3=v==optB and T.white or T.mute}):Play()
        if cb then cb(v) end
    end
    bA.MouseButton1Click:Connect(function() pick(optA) end)
    bB.MouseButton1Click:Connect(function() pick(optB) end)
    return row
end

-- Color picker (RGB sliders)
local function ColorPicker(parent, label, currentColor, cb)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1,0,0,120)
    row.BackgroundColor3 = T.card; row.BorderSizePixel = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0,8)
    local pad = Instance.new("UIPadding", row)
    pad.PaddingLeft = UDim.new(0,14); pad.PaddingRight = UDim.new(0,14); pad.PaddingTop = UDim.new(0,8)

    local lbl = Instance.new("TextLabel", row)
    lbl.Text = label; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 12
    lbl.TextColor3 = T.text; lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(0.7,0,0,16)
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local preview = Instance.new("Frame", row)
    preview.Size = UDim2.new(0,28,0,20); preview.Position = UDim2.new(1,-28,0,0)
    preview.BackgroundColor3 = currentColor; preview.BorderSizePixel = 0
    Instance.new("UICorner", preview).CornerRadius = UDim.new(0,4)

    local r, g, b = math.floor(currentColor.R*255), math.floor(currentColor.G*255), math.floor(currentColor.B*255)

    local function rebuild()
        local col = Color3.fromRGB(r,g,b)
        preview.BackgroundColor3 = col
        if cb then cb(col) end
    end

    local function makeRGBSlider(label2, yOff, initial, maxV, onCh)
        local track = Instance.new("Frame", row)
        track.Size = UDim2.new(1,0,0,4); track.Position = UDim2.new(0,0,0,yOff)
        track.BackgroundColor3 = T.raised; track.BorderSizePixel = 0
        Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
        local fill2 = Instance.new("Frame", track)
        fill2.Size = UDim2.new(initial/maxV,0,1,0); fill2.BackgroundColor3 = T.accent
        fill2.BorderSizePixel = 0; Instance.new("UICorner", fill2).CornerRadius = UDim.new(1,0)
        local dot2 = Instance.new("Frame", track)
        dot2.Size = UDim2.new(0,10,0,10); dot2.AnchorPoint = Vector2.new(0.5,0.5)
        dot2.Position = UDim2.new(initial/maxV,0,0.5,0); dot2.BackgroundColor3 = T.white
        dot2.BorderSizePixel = 0; Instance.new("UICorner", dot2).CornerRadius = UDim.new(1,0)
        local capLbl = Instance.new("TextLabel", row)
        capLbl.Text = label2; capLbl.Font = Enum.Font.GothamBold; capLbl.TextSize = 9
        capLbl.TextColor3 = T.mute; capLbl.BackgroundTransparency = 1
        capLbl.Size = UDim2.new(0,10,0,12); capLbl.Position = UDim2.new(0,-2,0,yOff-12)
        capLbl.TextXAlignment = Enum.TextXAlignment.Center
        track.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                S.ActiveSlider = {
                    track=track, fill=fill2, dot=dot2,
                    min=0, max=maxV,
                    setV=function(v)
                        onCh(math.floor(v))
                        rebuild()
                    end,
                    cb=nil
                }
            end
        end)
    end

    makeRGBSlider("R", 28, r, 255, function(v) r=v end)
    makeRGBSlider("G", 50, g, 255, function(v) g=v end)
    makeRGBSlider("B", 72, b, 255, function(v) b=v end)
    return row
end

