local function getNameLabel(char)
    if not char then return nil end
    local head=char:FindFirstChild("Head"); if not head then return nil end
    local nt=head:FindFirstChild("NameTag") or head:FindFirstChild("NameTagClone")
    if nt then
        local mf=nt:FindFirstChild("MainFrame",true)
        if mf then return mf:FindFirstChild("NameLabel",true) end
    end
    return nil
end

local function getRankLabel(char)
    if not char then return nil end
    local head=char:FindFirstChild("Head"); if not head then return nil end
    local rt=head:FindFirstChild("RankTag") or head:FindFirstChild("RankTagClone")
    if rt then
        local mf=rt:FindFirstChild("MainFrame",true)
        if mf then return mf:FindFirstChild("NameLabel",true) end
    end
    return nil
end

local function patchOverheadName(char,name)
