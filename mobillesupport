local function makeToggle(parent, lbl, yOff, stateTab, stateKey, cb)
    local row = Instance.new("Frame", parent)
    row.Size                   = UDim2.new(1, 0, 0, 40)
    row.Position               = UDim2.new(0, 0, 0, yOff)
    row.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", row)
    label.Text                 = lbl
    label.Font                 = Enum.Font.Gotham
    label.TextSize             = 13
    label.TextColor3           = C.text
    label.BackgroundTransparency = 1
    label.Size                 = UDim2.new(1, -70, 1, 0)
    label.Position             = UDim2.new(0, 12, 0, 0)
    label.TextXAlignment       = Enum.TextXAlignment.Left

    local track = Instance.new("Frame", row)
    track.Size             = UDim2.new(0, 44, 0, 24)
    track.Position         = UDim2.new(1, -56, 0.5, -12)
    track.BackgroundColor3 = C.bg3
    track.BorderSizePixel  = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame", track)
    knob.Size             = UDim2.new(0, 18, 0, 18)
    knob.Position         = UDim2.new(0, 3, 0.5, -9)
    knob.BackgroundColor3 = C.dim
    knob.BorderSizePixel  = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local hitbox = Instance.new("TextButton", track)
    hitbox.Text               = ""
    hitbox.BackgroundTransparency = 1
    hitbox.Size               = UDim2.new(1, 0, 1, 0)

    rowDiv(row, 39)

    local on = (stateTab ~= nil) and S[stateTab][stateKey] or false

    local function refresh(v)
        TweenService:Create(knob, TweenInfo.new(0.15), {
            Position         = v and UDim2.new(0, 23, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
            BackgroundColor3 = v and C.white or C.dim,
        }):Play()
        TweenService:Create(track, TweenInfo.new(0.15), {
            BackgroundColor3 = v and C.red or C.bg3,
        }):Play()
    end
    refresh(on)

    hitbox.MouseButton1Click:Connect(function()
        on = not on
        if stateTab then S[stateTab][stateKey] = on end
        refresh(on)
        if cb then cb(on) end
    end)

    return row
end

