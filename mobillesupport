-- Toggle row
local function Toggle(parent, label, sublabel, stateTab, stateKey, cb)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1,0,0,48)
    row.BackgroundColor3 = T.card; row.BorderSizePixel = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0,8)

    local pad = Instance.new("UIPadding", row)
    pad.PaddingLeft = UDim.new(0,14); pad.PaddingRight = UDim.new(0,14)

    local lbl = Instance.new("TextLabel", row)
    lbl.Text = label; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 13
    lbl.TextColor3 = T.text; lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1,-70,0,18); lbl.Position = UDim2.new(0,0,0,8)
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    if sublabel then
        local sub = Instance.new("TextLabel", row)
        sub.Text = sublabel; sub.Font = Enum.Font.Gotham; sub.TextSize = 10
        sub.TextColor3 = T.mute; sub.BackgroundTransparency = 1
        sub.Size = UDim2.new(1,-70,0,14); sub.Position = UDim2.new(0,0,0,27)
        sub.TextXAlignment = Enum.TextXAlignment.Left
    end

    -- Pill toggle
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(0,42,0,22); track.Position = UDim2.new(1,-42,0.5,-11)
    track.BackgroundColor3 = T.raised; track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0,16,0,16); knob.Position = UDim2.new(0,3,0.5,-8)
    knob.BackgroundColor3 = T.mute; knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    local hitbox = Instance.new("TextButton", track)
    hitbox.Text=""; hitbox.BackgroundTransparency=1; hitbox.Size=UDim2.new(1,0,1,0)

    local on = stateTab ~= nil and S[stateTab][stateKey] or false

    local function refresh(v)
        TweenService:Create(knob, TweenInfo.new(0.18, Enum.EasingStyle.Quart), {
            Position         = v and UDim2.new(0,23,0.5,-8) or UDim2.new(0,3,0.5,-8),
            BackgroundColor3 = v and T.white or T.mute,
        }):Play()
        TweenService:Create(track, TweenInfo.new(0.18, Enum.EasingStyle.Quart), {
            BackgroundColor3 = v and T.accent or T.raised,
        }):Play()
        TweenService:Create(row, TweenInfo.new(0.18), {
            BackgroundColor3 = v and Color3.fromRGB(28,16,18) or T.card,
        }):Play()
    end
    refresh(on)

    hitbox.MouseButton1Click:Connect(function()
        on = not on
        if stateTab then S[stateTab][stateKey] = on end
        refresh(on)
        if cb then cb(on) end
        notify(label, on and "Enabled" or "Disabled", on and "success" or nil)
    end)
    return row
end

-- Slider row
local function Slider(parent, label, unit, min, max, cur, cb)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1,0,0,56)
    row.BackgroundColor3 = T.card; row.BorderSizePixel = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0,8)

    local pad = Instance.new("UIPadding", row)
    pad.PaddingLeft = UDim.new(0,14); pad.PaddingRight = UDim.new(0,14)
    pad.PaddingTop  = UDim.new(0,8)

    local lbl = Instance.new("TextLabel", row)
    lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 12
    lbl.TextColor3 = T.text; lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(0.6,0,0,16); lbl.TextXAlignment = Enum.TextXAlignment.Left

    local valLbl = Instance.new("TextLabel", row)
    valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 12
    valLbl.TextColor3 = T.accent; valLbl.BackgroundTransparency = 1
    valLbl.Size = UDim2.new(0.4,-2,0,16); valLbl.TextXAlignment = Enum.TextXAlignment.Right

    local function setV(v)
        lbl.Text  = label
        valLbl.Text = string.format("%.1f", v) .. (unit or "")
    end
    setV(cur)

    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(1,0,0,4); track.Position = UDim2.new(0,0,0,30)
    track.BackgroundColor3 = T.raised; track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new((cur-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = T.accent; fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)

    local dot = Instance.new("Frame", track)
    dot.Size = UDim2.new(0,12,0,12); dot.AnchorPoint = Vector2.new(0.5,0.5)
    dot.Position = UDim2.new((cur-min)/(max-min),0,0.5,0)
    dot.BackgroundColor3 = T.white; dot.BorderSizePixel = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)

    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            S.ActiveSlider = {track=track,fill=fill,dot=dot,min=min,max=max,setV=setV,cb=cb}
        end
    end)
    return row
end

