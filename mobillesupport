    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            S.ActiveSlider = {track=track, fill=fill, dot=dot,
                              minV=minV, maxV=maxV, setVal=setVal, cb=cb}
        end
    end)
end

local function makeActionBtn(parent, lbl, yOff, accent, cb)
    local btn = Instance.new("TextButton", parent)
    btn.Text             = lbl
    btn.Font             = Enum.Font.Gotham
    btn.TextSize         = 13
    btn.TextColor3       = accent or C.text
    btn.BackgroundColor3 = C.bg2
    btn.Size             = UDim2.new(1, -24, 0, 34)
    btn.Position         = UDim2.new(0, 12, 0, yOff)
    btn.BorderSizePixel  = 0
    btn.AutoButtonColor  = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = C.bg3}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = C.bg2}):Play()
    end)
    btn.MouseButton1Click:Connect(function() if cb then cb(btn) end end)
    return btn
end

