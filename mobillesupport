    if S.Fly.Enabled then
        hum.PlatformStand = true
        local bv = Instance.new("BodyVelocity", root)
        bv.Name = "C3FlyVel"; bv.Velocity = Vector3.zero
        bv.MaxForce = Vector3.new(1e5,1e5,1e5)
        local bg = Instance.new("BodyGyro", root)
        bg.Name = "C3FlyGyro"; bg.MaxTorque = Vector3.new(1e5,1e5,1e5)
        bg.P = 1e4; bg.CFrame = root.CFrame
        S.Fly.Body = bv; S.Fly.Gyro = bg
    else
        hum.PlatformStand = false
        if S.Fly.Body then S.Fly.Body:Destroy(); S.Fly.Body = nil end
        if S.Fly.Gyro then S.Fly.Gyro:Destroy(); S.Fly.Gyro = nil end
    end
end)

