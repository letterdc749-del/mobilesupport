local function clearWallbang()
    local toRm={}
    for part,hl in pairs(S.Wallbang.Highlights) do table.insert(toRm,{part,hl}) end
    for _,e in ipairs(toRm) do pcall(function() e[2]:Destroy() end); S.Wallbang.Highlights[e[1]]=nil end
end

RunService.Heartbeat:Connect(function(dt)
    wbT=wbT+dt
    if not S.Wallbang.Enabled then if next(S.Wallbang.Highlights) then clearWallbang() end return end
    if wbT<0.15 then return end; wbT=0
    clearWallbang()
    local char=LP.Character; if not char then return end
    S.Wallbang.Params.FilterDescendantsInstances={char}
    local orig=Cam.CFrame.Position; local lv=Cam.CFrame.LookVector
    local castOrig=orig
    for _=1,5 do
        local res=workspace:Raycast(castOrig,lv*300,S.Wallbang.Params); if not res then break end
        local part=res.Instance
        if part and part:IsA("BasePart") then
            local pen=part.Transparency>=0.5 or not part.CanCollide
            if not pen then
                local ok,d=pcall(function() return part.CurrentPhysicalProperties.Density end)
                if ok and d<0.5 then pen=true end
                local sz=part.Size; if sz.X<0.5 or sz.Y<0.5 or sz.Z<0.5 then pen=true end
            end
            if pen and not S.Wallbang.Highlights[part] then
                local hl=Instance.new("Highlight")
                hl.FillColor=T.orange; hl.OutlineColor=T.orange
                hl.FillTransparency=0.5; hl.OutlineTransparency=0.1
                hl.Adornee=part; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
                hl.Parent=part; S.Wallbang.Highlights[part]=hl
            end
        end
        castOrig=res.Position+lv*0.05
    end
end)

