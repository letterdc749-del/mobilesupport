local function removeESP(player)
    if S.ESP.HPConns[player]    then S.ESP.HPConns[player]:Disconnect(); S.ESP.HPConns[player]=nil end
    if S.ESP.Tags[player]       then S.ESP.Tags[player]:Destroy();       S.ESP.Tags[player]=nil end
    if S.ESP.Highlights[player] then S.ESP.Highlights[player]:Destroy(); S.ESP.Highlights[player]=nil end
    if S.ESP.Boxes[player]      then S.ESP.Boxes[player]:Destroy();      S.ESP.Boxes[player]=nil end
end

local function buildESP(player)
    if player == LP then return end
    removeESP(player)
    local char=player.Character; if not char then return end
    local head=char:FindFirstChild("Head")
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not head or not hum then return end

    -- Highlight
    local hl = Instance.new("Highlight")
    hl.FillColor=S.ESP.Color; hl.OutlineColor=S.ESP.Color
    hl.FillTransparency=0.72; hl.OutlineTransparency=0.1
    hl.Adornee=char; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent=char; S.ESP.Highlights[player]=hl

    -- BillboardGui
    local bb=Instance.new("BillboardGui")
    bb.Name="C3ESP"; bb.Size=UDim2.new(0,90,0,32)
    bb.StudsOffset=Vector3.new(0,2.8,0); bb.AlwaysOnTop=true
    bb.MaxDistance=S.ESP.Distance; bb.Adornee=head; bb.Parent=head
    S.ESP.Tags[player]=bb

    local nameTag=Instance.new("TextLabel",bb)
    nameTag.Text=player.Name; nameTag.Font=Enum.Font.GothamBold; nameTag.TextSize=11
    nameTag.TextColor3=T.white; nameTag.BackgroundTransparency=1
    nameTag.Size=UDim2.new(1,0,0,16); nameTag.TextXAlignment=Enum.TextXAlignment.Center
    nameTag.TextStrokeTransparency=0.3; nameTag.TextStrokeColor3=T.black

    local hpBG=Instance.new("Frame",bb)
    hpBG.Size=UDim2.new(1,0,0,4); hpBG.Position=UDim2.new(0,0,0,17)
    hpBG.BackgroundColor3=Color3.fromRGB(25,8,8); hpBG.BorderSizePixel=0
    Instance.new("UICorner",hpBG).CornerRadius=UDim.new(1,0)

    local hpFill=Instance.new("Frame",hpBG)
    hpFill.Size=UDim2.new(hum.Health/math.max(hum.MaxHealth,1),0,1,0)
    hpFill.BackgroundColor3=T.green; hpFill.BorderSizePixel=0
    Instance.new("UICorner",hpFill).CornerRadius=UDim.new(1,0)

    local hpLbl=Instance.new("TextLabel",bb)
    hpLbl.Font=Enum.Font.GothamBold; hpLbl.TextSize=8; hpLbl.TextColor3=T.green
    hpLbl.BackgroundTransparency=1; hpLbl.Size=UDim2.new(1,0,0,10); hpLbl.Position=UDim2.new(0,0,0,22)
    hpLbl.TextXAlignment=Enum.TextXAlignment.Center
    hpLbl.TextStrokeTransparency=0.4; hpLbl.TextStrokeColor3=T.black

    -- Box ESP (2D AdornGui box around HumanoidRootPart)
    if S.ESP.ShowBox then
        local boxBB=Instance.new("BillboardGui")
        boxBB.Name="C3Box"; boxBB.Size=UDim2.new(0,0,0,0)
        boxBB.SizeOffset=Vector2.new(3.5,5)
        boxBB.StudsOffset=Vector3.new(0,0,0)
        boxBB.AlwaysOnTop=true; boxBB.MaxDistance=S.ESP.Distance
        local root=char:FindFirstChild("HumanoidRootPart")
        boxBB.Adornee=root or char; boxBB.Parent=char
        local boxFrame=Instance.new("Frame",boxBB)
        boxFrame.Size=UDim2.new(1,0,1,0); boxFrame.BackgroundTransparency=1
        boxFrame.BorderSizePixel=0
        local stroke=Instance.new("UIStroke",boxFrame)
        stroke.Color=S.ESP.Color; stroke.Thickness=1.5; stroke.Transparency=0.1
        S.ESP.Boxes[player]=boxBB
    end

    local conn=RunService.Heartbeat:Connect(function()
        if not bb.Parent or not hum.Parent then removeESP(player); return end
        local pct=math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1)
        hpFill.Size=UDim2.new(pct,0,1,0)
        hpFill.BackgroundColor3=pct>0.5 and T.green or T.accent
        hpLbl.Text=math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
        hpLbl.TextColor3=hpFill.BackgroundColor3
        nameTag.Visible=S.ESP.ShowName; hpBG.Visible=S.ESP.ShowHealth; hpLbl.Visible=S.ESP.ShowHealth
    end)
    S.ESP.HPConns[player]=conn
end

