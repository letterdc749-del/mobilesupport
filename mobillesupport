-- Connect kill detection via Humanoid.Died on all characters
local function watchPlayerDeaths(player)
    player.CharacterAdded:Connect(function(char)
        local hum = char:WaitForChild("Humanoid", 10)
        if not hum then return end
        hum.Died:Connect(function()
            if not S.KillFeed.Enabled then return end
            addKillEntry("💀  " .. player.DisplayName .. " died")
        end)
    end)
    -- Also hook existing character
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.Died:Connect(function()
                if not S.KillFeed.Enabled then return end
                addKillEntry("💀  " .. player.DisplayName .. " died")
            end)
        end
    end
end

for _, p in ipairs(Players:GetPlayers()) do watchPlayerDeaths(p) end
Players.PlayerAdded:Connect(watchPlayerDeaths)

