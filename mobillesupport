-- Safe Drawing wrapper — works on Delta and most executors
local DrawingLib = Drawing or (getgenv and getgenv().Drawing) or nil
local function newDrawing(type)
    if DrawingLib then
        return DrawingLib.new(type)
    end
    -- Fallback stub so script doesn't crash if Drawing unavailable
    local stub = {}
    local mt = {__index = function() return stub end, __newindex = function() end}
    setmetatable(stub, mt)
    stub.Remove = function() end
    return stub
end

