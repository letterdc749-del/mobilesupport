local NotifLayout = Instance.new("UIListLayout", NotifFrame)
NotifLayout.SortOrder        = Enum.SortOrder.LayoutOrder
NotifLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
NotifLayout.Padding           = UDim.new(0, 6)
local notifCount = 0

local function notify(title, msg, ntype)
    notifCount = notifCount + 1
    local color = ntype == "success" and T.green or ntype == "warn" and T.yellow or T.accent
    local n = Instance.new("Frame", NotifFrame)
    n.Size             = UDim2.new(1, 0, 0, 56)
    n.BackgroundColor3 = T.surface
    n.BorderSizePixel  = 0
    n.LayoutOrder      = notifCount
    n.ClipsDescendants = true
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 8)

    local bar = Instance.new("Frame", n)
    bar.Size             = UDim2.new(0, 3, 1, 0)
    bar.BackgroundColor3 = color
    bar.BorderSizePixel  = 0
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 3)

    local t = Instance.new("TextLabel", n)
    t.Text                 = title
    t.Font                 = Enum.Font.GothamBold
    t.TextSize             = 13
    t.TextColor3           = T.text
    t.BackgroundTransparency = 1
    t.Size                 = UDim2.new(1, -16, 0, 18)
    t.Position             = UDim2.new(0, 12, 0, 8)
    t.TextXAlignment       = Enum.TextXAlignment.Left

    local m = Instance.new("TextLabel", n)
    m.Text                 = msg
    m.Font                 = Enum.Font.Gotham
    m.TextSize             = 11
    m.TextColor3           = T.sub
    m.BackgroundTransparency = 1
    m.Size                 = UDim2.new(1, -16, 0, 14)
    m.Position             = UDim2.new(0, 12, 0, 28)
    m.TextXAlignment       = Enum.TextXAlignment.Left
    m.TextWrapped          = true

    -- Progress bar
    local prog = Instance.new("Frame", n)
    prog.Size             = UDim2.new(1, 0, 0, 2)
    prog.Position         = UDim2.new(0, 0, 1, -2)
    prog.BackgroundColor3 = color
    prog.BorderSizePixel  = 0
    TweenService:Create(prog, TweenInfo.new(3, Enum.EasingStyle.Linear), {Size = UDim2.new(0,0,0,2)}):Play()

    -- Slide in
    n.Position = UDim2.new(1, 10, 0, 0)
    TweenService:Create(n, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0)
    }):Play()

    task.delay(3, function()
        if n.Parent then
            TweenService:Create(n, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
                Position = UDim2.new(1, 10, 0, 0)
            }):Play()
            task.wait(0.26)
            if n.Parent then n:Destroy() end
        end
    end)
end

